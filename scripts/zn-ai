# =============================================================================
# 工具配置
# =============================================================================

# 检测可用的编辑器
detect_editor() {
    if command -v code &> /dev/null; then
        echo "code"
    elif command -v vim &> /dev/null; then
        echo "vim"
    elif command -v nano &> /dev/null; then
        echo "nano"
    elif command -v open &> /dev/null; then
        # macOS open 命令，可打开文件进行编辑
        echo "open"
    fi
}

# 通用的配置文件打开函数
# 参数: $1=配置文件路径 $2=工具名称 $3=默认配置内容
open_or_init_config() {
    local config_file=$1
    local tool_name=$2
    local default_content=$3

    if [ -f "$config_file" ]; then
        print_info "配置文件: $config_file"
        local editor=$(detect_editor)
        if [ -n "$editor" ]; then
            print_step "使用 $editor 打开..."
            $editor "$config_file"
        else
            print_warning "未检测到可用编辑器"
            print_info "请手动打开: $config_file"
        fi
    else
        print_warning "配置文件不存在"
        if confirm "是否创建默认配置？"; then
            mkdir -p "$(dirname "$config_file")"
            echo "$default_content" > "$config_file"
            print_success "默认配置已创建: $config_file"
            local editor=$(detect_editor)
            if [ -n "$editor" ]; then
                print_step "使用 $editor 打开..."
                $editor "$config_file"
            else
                print_warning "未检测到可用编辑器"
                print_info "请手动打开: $config_file"
            fi
        fi
    fi
}

config_nova_settings() {
    print_section "配置 Nova"

    local config_file="$HOME/.nova/settings.json"

    # Nova 默认配置
    local default_config='{
  "env": {
    "ANTHROPIC_AUTH_TOKEN": "",
    "ANTHROPIC_BASE_URL": "https://zn-nova.paic.com.cn/novai",
    "ANTHROPIC_MODEL": "qwen3.6-plus",
    "ANTHROPIC_SMALL_FAST_MODEL": "MiniMax-M2.7-highspeed",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "glm-5",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "glm-5.1",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "MiniMax-M2.7-highspeed"
  }
}'

    open_or_init_config "$config_file" "Nova" "$default_config"
    wait_key
}

config_opencode_settings() {
    print_section "配置 OpenCode"

    # OpenCode 配置文件可能是 .json 或 .jsonc
    local opencode_dir="$HOME/.config/opencode"
    local config_file=""

    if [ -f "$opencode_dir/opencode.jsonc" ]; then
        config_file="$opencode_dir/opencode.jsonc"
    elif [ -f "$opencode_dir/opencode.json" ]; then
        config_file="$opencode_dir/opencode.json"
    fi

    if [ -n "$config_file" ]; then
        print_info "配置文件: $config_file"
        local editor=$(detect_editor)
        if [ -n "$editor" ]; then
            print_step "使用 $editor 打开..."
            $editor "$config_file"
        else
            print_warning "未检测到可用编辑器"
            print_info "请手动打开: $config_file"
        fi
    else
        print_warning "配置文件不存在"
        print_info "OpenCode 会在首次运行时自动创建配置"
        local editor=$(detect_editor)
        if [ -n "$editor" ]; then
            print_step "使用 $editor 打开配置目录..."
            $editor "$opencode_dir"
        else
            print_warning "未检测到可用编辑器"
            print_info "请手动打开: $opencode_dir"
        fi
    fi

    wait_key
}

config_opencc_settings() {
    print_section "配置 OpenCC"

    local config_file="$HOME/.claude/settings.json"

    # OpenCC 默认配置
    local default_config='{
  "env": {
    "ANTHROPIC_AUTH_TOKEN": "",
    "API_TIMEOUT_MS": "3000000",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "ANTHROPIC_BASE_URL": "https://zn-nova.paic.com.cn/novai",
    "ANTHROPIC_MODEL": "qwen3.6-plus",
    "ANTHROPIC_SMALL_FAST_MODEL": "MiniMax-M2.7-highspeed",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "glm-5",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "glm-5.1",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "MiniMax-M2.7-highspeed"
  }
}'

    open_or_init_config "$config_file" "OpenCC" "$default_config"
    wait_key
}

show_env_guide() {
    print_section "环境配置指南"
    
    cat << 'EOF'

┌─────────────────────────────────────────────────────────────┐
│                      环境配置步骤                           │
└─────────────────────────────────────────────────────────────┘

1. 配置 npm 镜像源 (本工具已提供)
   npm config set registry http://maven.paic.com.cn/repository/npm/

2. 安装 CLI 工具 (本工具已提供)
   npm install -g @zn-ai/nova
   npm install -g opencode-ai
   npm install -g @zn-ai/opencc
   npm install -g @zn-ai/agent-login@latest

3. 登录 (本工具已提供)
   npx @zn-ai/agent-login@latest pa      # PA 神兵登录
   npx @zn-ai/agent-login@latest op      # 开放平台登录

4. OpenCode 配置插件 (本工具已提供)
   cd ~/.config/opencode
   npm init -y
   npm install @zn-ai/agent-login@latest
   # 添加插件到 opencode.json

5. OpenCC 配置 (本工具已提供)
   # 创建 ~/.claude/settings.json
   # 配置 ANTHROPIC_BASE_URL 和模型

详细文档: docs/AI_CLI_SETUP.md

EOF
    
    wait_key
}

# =============================================================================
# 快速启动
# =============================================================================

quick_start() {
    print_section "快速启动"
    
    echo "正在检查环境..."
    echo ""
    
    local missing=()
    
    # 检查 Node.js
    if ! command -v node &> /dev/null; then
        missing+=("Node.js")
    fi
    
    # 检查 npm
    if ! command -v npm &> /dev/null; then
        missing+=("npm")
    fi
    
    if [ ${#missing[@]} -gt 0 ]; then
        print_error "缺少必要环境: ${missing[*]}"
        print_info "请先安装 Node.js: https://nodejs.org/"
        wait_key
        return
    fi
    
    # 检查并安装工具
    print_step "检查 CLI 工具..."
    
    local tools=("nova:@zn-ai/nova" "opencode:opencode-ai" "opencc:@zn-ai/opencc" "agent-login:@zn-ai/agent-login")
    local to_install=()
    
    for tool in "${tools[@]}"; do
        IFS=':' read -r cmd pkg <<< "$tool"
        if ! command -v $cmd &> /dev/null; then
            to_install+=("$pkg")
        fi
    done
    
    if [ ${#to_install[@]} -gt 0 ]; then
        print_warning "发现未安装的工具: ${to_install[*]}"
        if confirm "是否自动安装？"; then
            for pkg in "${to_install[@]}"; do
                print_step "安装 $pkg..."
                npm install -g "$pkg" --registry="$NPM_REGISTRY" 2>/dev/null
            done
        fi
    else
        print_success "所有 CLI 工具已安装"
    fi
    
    # 配置
    print_step "配置 npm 镜像源..."
    npm config set registry "$NPM_REGISTRY" 2>/dev/null || true
    print_success "完成"
    
    echo ""
    print_success "快速启动完成!"
    print_info "下一步: 运行 'login' 命令进行登录"
    
    wait_key
}

# =============================================================================
# 主菜单
# =============================================================================

show_menu() {
    clear
    print_header

    # 显示基础信息
    echo -e "  ${DIM}基础信息${NC}"

    # Node 版本
    if command -v node &> /dev/null; then
        echo -e "    Node.js: ${GREEN}$(node --version)${NC}"
    else
        echo -e "    Node.js: ${RED}未安装${NC}"
    fi

    # CLI 安装状态
    local cli_list=""
    command -v nova &> /dev/null && cli_list+="${MAGENTA}Nova${NC} "
    command -v opencode &> /dev/null && cli_list+="${GREEN}OpenCode${NC} "
    command -v opencc &> /dev/null && cli_list+="${YELLOW}OpenCC${NC} "
    if [ -n "$cli_list" ]; then
        echo -e "    CLI: ${cli_list}"
    else
        echo -e "    CLI: ${RED}未安装${NC}"
    fi

    echo ""
    echo -e "  ${BOLD}请选择操作:${NC}"
    echo ""

    local options=(
        "🔑 PA 神兵登录"
        "🌐 开放平台登录"
        "📦 资源安装"
        "🔧 工具安装"
        "📊 系统信息"
        "⚙️ 工具配置"
        "🚀 快速启动"
        "👋 退出"
    )

    local i=1
    for opt in "${options[@]}"; do
        printf "    ${CYAN}%d${NC}. %s\n" "$i" "$opt"
        ((i++))
    done

    echo ""
}
# =============================================================================
# 子菜单
# =============================================================================

show_install_menu() {
     while true; do
         clear
         print_header
         echo -e "  ${BOLD}工具安装/更新${NC}"
         echo ""

         local options=(
             "安装/更新 Nova CLI"
             "安装/更新 OpenCode CLI"
             "安装/更新 OpenCC"
             "安装/更新所有工具"
             "返回主菜单"
         )

         local i=1
         for opt in "${options[@]}"; do
             printf "    ${CYAN}%d${NC}. %s\n" "$i" "$opt"
             ((i++))
         done

         echo ""
         echo -n "请选择 (1-5, ESC 返回): "
         choice=$(read_key)
         echo "$choice"

         # 检测 ESC 键
         if [[ "$choice" == $'\e' ]]; then
             break
         fi

         case $choice in
             1) install_nova_cli ;;
             2) install_opencode_cli ;;
             3) install_opencc ;;
             4) install_all_tools ;;
             5) break ;;
             *) print_error "无效选择" ;;
         esac
     done
}
show_resource_menu() {
    while true; do
        clear
        print_header
        echo -e "  ${BOLD}资源安装${NC}"
        echo ""

        local options=(
            "浏览 Skills"
            "浏览 Commands"
            "浏览 Plugins"
            "浏览 Agents"
            "返回主菜单"
        )

        local i=1
        for opt in "${options[@]}"; do
            printf "    ${CYAN}%d${NC}. %s\n" "$i" "$opt"
            ((i++))
        done

        echo ""
        echo -n "请选择 (1-5, ESC 返回): "
        choice=$(read_key)
        echo "$choice"

        # 检测 ESC 键
        if [[ "$choice" == $'\e' ]]; then
            break
        fi

        case $choice in
            1) browse_and_install_resource "skills" ;;
            2) browse_and_install_resource "commands" ;;
            3) browse_and_install_resource "plugins" ;;
            4) browse_and_install_resource "agents" ;;
            5) break ;;
            *) print_error "无效选择" ;;
        esac
    done
}

show_config_menu() {
    while true; do
        clear
        print_header
        echo -e "  ${BOLD}工具配置${NC}"
        echo ""

        local options=(
            "配置 Nova"
            "配置 OpenCode"
            "配置 OpenCC"
            "返回主菜单"
        )

        local i=1
        for opt in "${options[@]}"; do
            printf "    ${CYAN}%d${NC}. %s\n" "$i" "$opt"
            ((i++))
        done

        echo ""
        echo -n "请选择 (1-4, ESC 返回): "
        choice=$(read_key)
        echo "$choice"

        # 检测 ESC 键
        if [[ "$choice" == $'\e' ]]; then
            break
        fi

        case $choice in
            1) config_nova_settings ;;
            2) config_opencode_settings ;;
            3) config_opencc_settings ;;
            4) break ;;
            *) print_error "无效选择" ;;
        esac
    done
}

# =============================================================================
# 主程序
# =============================================================================

main() {
    # 确保使用 bash
    if [ -z "$BASH_VERSION" ]; then
        echo "请使用 bash 运行此脚本: bash $0"
        exit 1
    fi

    while true; do
        show_menu
        echo -n "请选择 (1-8, ESC 返回): "
        choice=$(read_key)
        echo "$choice"

        # 检测 ESC 键 (ASCII 27)
        if [[ "$choice" == $'\e' ]]; then
            echo ""
            echo -e "${BOLD}${GREEN}感谢使用!${NC}"
            echo ""
            exit 0
        fi

        case $choice in
            1) login_pa ;;
            2) login_openplatform ;;
            3) show_resource_menu ;;
            4) show_install_menu ;;
            5) show_all_system_info ;;
            6) show_config_menu ;;
            7) quick_start ;;
            8)
                echo ""
                echo -e "${BOLD}${GREEN}感谢使用!${NC}"
                echo ""
                exit 0
                ;;
            *)
                if [[ -n "$choice" ]]; then
                    print_error "无效选择，请输入 1-8"
                    sleep 1
                fi
                ;;
        esac
    done
}
# 运行
main "$@"
