{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "noEmitOnError": false,
    "ignoreDeprecations": "5.0",
    "baseUrl": ".",
    "paths": {
      "../opencc-internals/*": ["./src/types/opencc-internals-stubs/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/types/opencc-internals-stubs/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/opencc-internals"
  ]
}

