{
  "name": "@zn-ai/zai-agent-core",
  "version": "0.1.0",
  "description": "知鸟AI agent runtime core — 从 OpenCC 抽离的对话/工具/Skills/MCP/transcript 核心",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./runtime": "./dist/runtime/index.js",
    "./transcript": "./dist/transcript/store.js",
    "./commands": "./dist/commands/index.js",
    "./bashTracker": "./dist/tools/BashTool/bashTracker.js",
    "./taskListStore": "./dist/tools/Tasks/TaskListStore.js",
    "./agents/memoryWatcher": "./dist/agents/memoryWatcher.js",
    "./agents/memoryLoader": "./dist/agents/memoryLoader.js"
  },
  "files": [
    "dist/",
    "src/opencc-internals/"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "sync-from-opencc": "tsx scripts/sync-from-opencc.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@modelcontextprotocol/sdk": "^1.6.1",
    "ajv": "^8.17.1",
    "ignore": "^5.3.2",
    "ajv-formats": "^3.0.1",
    "axios": "^1.7.7",
    "eventsource-parser": "^1.1.2",
    "js-yaml": "^4.3.0",
    "lodash-es": "^4.17.21",
    "p-map": "^4.0.0",
    "proper-lockfile": "^4.1.2",
    "react": "^18.3.1",
    "ws": "^8.18.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.12.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^18.3.12",
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://nexus.paic.com.cn/repository/npm-internal/"
  }
}
